# Copy to .env.local and fill in real values. All .env / .env.* files are gitignored;
# .env.example is the only committable one.

# Local database — Prisma reads this from .env (or .env.local) at dev time;
# in deploy this is set as a Vercel env var instead.
DATABASE_URL="file:./dev.db"

# Auth.js — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# LLM proxy (NewAPI-style; the same key can serve OpenAI- and Anthropic-style endpoints)
# Note: OpenAI SDK's baseURL should include /v1; Anthropic SDK's should not.
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL=""

# Defaults
DEFAULT_PROVIDER="mock"            # mock | openai | anthropic
DEFAULT_OPENAI_MODEL="gpt-4o-mini"
DEFAULT_ANTHROPIC_MODEL="claude-haiku-4-5"

# Race Mode candidate pool. Comma-separated model IDs (e.g. gpt-4o-mini,deepseek-chat,claude-haiku-4-5,grok-2-mini)
# Leave empty during development to fall back to Mock candidates.
RACE_AVAILABLE_MODELS=""
