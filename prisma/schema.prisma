// Atoms Demo schema.
// SPEC §5. Auth.js v5 with JWT session strategy — no Account/Session tables needed.
// SQLite-friendly: no native enums (validate string unions in Zod), no arrays.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  locale       String   @default("zh")
  credits      Int      @default(1000)
  createdAt    DateTime @default(now())

  projects Project[]
}

model Project {
  id           String   @id @default(cuid())
  ownerId      String
  name         String
  defaultMode  String   @default("chat") // chat | team | race
  providerPref String? // JSON-encoded { protocol, model } or null
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([ownerId])
}

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  title     String?
  mode      String   @default("chat") // chat | team | race
  createdAt DateTime @default(now())

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([projectId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String // user | assistant | system
  agent          String? // mike | emma | bob | alex | david | iris | sarah
  content        String
  tokensIn       Int      @default(0)
  tokensOut      Int      @default(0)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
